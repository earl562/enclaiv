# ---------------------------------------------------------------------------
# Enclaiv — .gitignore
# ---------------------------------------------------------------------------

# ---- Secrets / environment ------------------------------------------------
.env
.env.local
.env.development
.env.production
.env.test
.env.*.local
*.pem
*.key
*.p12
*.pfx

# ---- Python ---------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
*.egg
.eggs/
.venv/
venv/
env/
ENV/
pip-wheel-metadata/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
coverage.xml
htmlcov/
*.cover
*.log
.hypothesis/

# ---- Go -------------------------------------------------------------------
bin/
*.exe
*.exe~
*.dll
*.dylib
*.test
*.out
vendor/

# ---- Unikraft / KraftKit --------------------------------------------------
.unikraft/
.kraftignore

# ---- Docker ---------------------------------------------------------------
.docker/

# ---- Node (for any tooling) -----------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---- OS -------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini

# ---- IDE / editor ---------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ---- Build / CI artefacts -------------------------------------------------
*.tar.gz
*.zip
*.tgz
coverage.out
trivy-results.sarif

# ---- Project-specific -----------------------------------------------------
# Operator config must never be committed to agent repos.
# (The repo root enclaiv.yaml is an example only — keep it tracked.)
.enclaiv/
